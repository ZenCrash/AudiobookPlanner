@using AudiobookPlanner.Blazor.Application.Views.Audiobooks

@inject IAudiobooksManager AudiobooksManager

@page "/Audiobooks"

<h3>AudiobookList</h3>

<table class="table">
  <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">Title</th>
      <th scope="col">Book Number</th>
      <th scope="col">Series</th>
      <th scope="col">Description</th>
      <th scope="col">Length</th>
      <th scope="col">ReleaseDate</th>
      <th scope="col">Publishers</th>
      <th scope="col">Authors</th>
      <th scope="col">Narrators</th>
      <th scope="col">Languages</th>
      <th scope="col">Genres</th>
      <th scope="col">Tags</th>
      <th scope="col">Ratings</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var audiobook in _audiobooks)
    {
      <tr>
        <th scope="row">@audiobook.Id</th>
        <td>@audiobook.Title</td>
        <td>@audiobook.BookNo</td>
        <td>@(audiobook.Series != null ? audiobook.Series.Title : "") </td>
        <td>@audiobook.Description</td>
        <td>@audiobook.LengthInMinutes</td>
        <td>@audiobook.ReleaseDate</td>
        <td>@(audiobook.Publisher != null ? audiobook.Publisher.Name : "-") </td>
        <td>@string.Join(", ", audiobook.Authors.Select(a => a.Name))</td>
        <td>@string.Join(", ", audiobook.Narrators.Select(n => n.Name))</td>
        <td>@string.Join(", ", audiobook.Languages.Select(l => l.LanguageName))</td>
        <td>@string.Join(", ", audiobook.Genres.Select(g => g.Name))</td>
        <td>@string.Join(", ", audiobook.Tags.Select(t => t.Name))</td>
        <td>@string.Join(", ", audiobook.Ratings.Select(r => r.RatingAvg))</td>
      </tr>
    }
  </tbody>
</table>

@code {
  private List<Audiobook> _audiobooks = [];

  protected override async Task OnInitializedAsync()
  {
    _audiobooks = await GetAudiobooks();
  }

  private async Task<List<Audiobook>> GetAudiobooks()
  {
    var audiobooks = await AudiobooksManager.GetAllAsync();
    return audiobooks.ToList();
  }

}
